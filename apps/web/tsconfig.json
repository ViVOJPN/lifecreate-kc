{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "noEmit": true,
    "incremental": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@lifecreate/schema": ["../../packages/schema/src"],
      "@lifecreate/schema/*": ["../../packages/schema/src/*"],
      "@lifecreate/market-reference": ["../../packages/market-reference/src"],
      "@lifecreate/market-reference/*": ["../../packages/market-reference/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
